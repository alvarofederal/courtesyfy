{
  "name": "courtesyfy",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "clean": "rimraf .next",
    "dev": "next dev --turbopack",
    "build:double": "next build && next build",
    "build": "node scripts/update-version.js && prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "next lint",
    "stripe:listen": "stripe listen --forward-to https://courtesyfy.vercel.app/api/webhook",
    "db:seed": "tsx prisma/seed.ts",
    "migrate:status": "npx prisma migrate status",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:resolve-applied": "npx prisma migrate resolve --applied",
    "postinstall": "prisma generate",
    "populate-slugs": "npx scripts/populate-slugs.ts",
    "patch": "npm version patch",
    "end-sprint": "npm version minor",
    "release": "npm version major",
    "//cache-buster": "v1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.10.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "5.17.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@stripe/stripe-js": "^8.3.0",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@vercel/speed-insights": "^1.2.0",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^3.0.3",
    "lucide-react": "^0.544.0",
    "mysql2": "^3.15.3",
    "nanoid": "^5.1.6",
    "next": "16.0.10",
    "next-auth": "^5.0.0-beta.30",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-datepicker": "^8.7.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.63.0",
    "recharts": "^3.3.0",
    "resend": "^6.5.2",
    "sonner": "^2.0.7",
    "stripe": "^19.2.1",
    "tailwind-merge": "^3.3.1",
    "twilio": "^5.10.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode.react": "^1.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.21",
    "install": "^0.13.0",
    "prisma": "5.17.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5"
  }
}

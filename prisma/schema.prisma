// prisma/schema.prisma

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ─────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(LOJISTA)
  ativo         Boolean   @default(true)
  ultimoAcesso  DateTime?
  lojaId        String?

  loja          Loja?       @relation(fields: [lojaId], references: [id])
  accounts      Account[]
  sessions      Session[]
  authTokens    AuthToken[]
  resgates      Resgate[]
  logsEventos   LogEvento[]
  chavesCancel           Chave[]                @relation("CanceladoPor")
  campanhasCria          Campanha[]             @relation("CriadoPor")
  lotesGerados           LoteChave[]            @relation("GeradoPor")
  impressoesAprovadas    SolicitacaoImpressao[] @relation("ImpressaoAprovacao")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([lojaId])
  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model AuthToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique @db.VarChar(500)
  type      TokenType
  expiresAt DateTime
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("auth_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_attempts")
}

// ─────────────────────────────────────────
// DOMÍNIO COURTESYFY
// ─────────────────────────────────────────

model Loja {
  id           String     @id @default(cuid())
  nome         String
  razaoSocial  String?
  cnpjCpf      String?    @unique
  email        String     @unique
  telefone     String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?    @db.Char(2)
  cep          String?
  logoUrl      String?    @db.Text
  corPrimaria  String     @default("#c8a96e")
  nomeExibicao String?
  siteUrl      String?    @db.Text
  status       LojaStatus @default(ATIVA)
  plano        Plano      @default(ESSENCIAL)

  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Impressão: PROPRIO = lojista imprime sozinho | ADMIN_COURTESYFY = solicita ao admin
  tipoImpressao TipoImpressao @default(PROPRIO)

  usuarios               User[]
  campanhas              Campanha[]
  lotes                  LoteChave[]
  chaves                 Chave[]
  resgates               Resgate[]
  logsEventos            LogEvento[]
  layouts                Layout[]
  solicitacoesImpressao  SolicitacaoImpressao[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("lojas")
}

model Layout {
  id             String      @id @default(cuid())
  lojaId         String
  nome           String
  corPrimaria    String      @default("#c8a96e")
  corFundo       String      @default("#fffdf7")
  corTexto       String      @default("#3a2510")
  corSecundaria  String      @default("#5a3e28")
  imagem1Url     String?     @db.Text
  imagem2Url     String?     @db.Text
  imagem3Url     String?     @db.Text
  opacidadeFundo Int         @default(20)
  brilho         Int         @default(100)
  saturacao      Int         @default(100)
  contraste      Int         @default(100)
  tamanhoCard    TamanhoCard @default(PADRAO)
  estiloCard     EstiloCard  @default(CLASSICO)
  raioCantos     Int         @default(8)
  padrao         Boolean     @default(false)

  loja                  Loja                   @relation(fields: [lojaId], references: [id])
  campanhas             Campanha[]
  solicitacoesImpressao SolicitacaoImpressao[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([lojaId])
  @@map("layouts")
}

model Campanha {
  id               String         @id @default(cuid())
  lojaId           String
  layoutId         String?
  nome             String
  descricao        String?        @db.Text
  tipoBeneficio    TipoBeneficio
  valorBeneficio   Decimal?       @db.Decimal(10, 2)
  descricaoPremio  String?        @db.Text
  regrasUso        String?        @db.Text
  quantidadeChaves Int
  inicioEm         DateTime
  expiraEm         DateTime
  status           CampanhaStatus @default(RASCUNHO)
  landingPageSlug  String?        @unique
  criadoPorId      String?

  loja                  Loja                   @relation(fields: [lojaId], references: [id])
  layout                Layout?                @relation(fields: [layoutId], references: [id])
  criadoPor             User?                  @relation("CriadoPor", fields: [criadoPorId], references: [id])
  lotes                 LoteChave[]
  chaves                Chave[]
  resgates              Resgate[]
  logsEventos           LogEvento[]
  solicitacoesImpressao SolicitacaoImpressao[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([lojaId])
  @@index([layoutId])
  @@index([criadoPorId])
  @@index([status])
  @@index([expiraEm])
  @@map("campanhas")
}

model LoteChave {
  id           String       @id @default(cuid())
  campanhaId   String
  lojaId       String
  descricao    String?
  quantidade   Int
  geradoPorId  String?
  formatoSaida FormatoSaida @default(A4)
  arquivoUrl   String?      @db.Text
  status       LoteStatus   @default(GERADO)

  campanha              Campanha               @relation(fields: [campanhaId], references: [id])
  loja                  Loja                   @relation(fields: [lojaId], references: [id])
  geradoPor             User?                  @relation("GeradoPor", fields: [geradoPorId], references: [id])
  chaves                Chave[]
  solicitacoesImpressao SolicitacaoImpressao[]

  criadoEm DateTime @default(now())

  @@index([campanhaId])
  @@index([lojaId])
  @@index([geradoPorId])
  @@map("lotes_chaves")
}

model Chave {
  id             String      @id @default(cuid())
  codigo         String      @unique
  loteId         String
  campanhaId     String
  lojaId         String
  clienteId      String?
  status         ChaveStatus @default(GERADA)
  qrcodeUrl      String?     @db.Text
  landingUrl     String?     @db.Text
  ativadaEm      DateTime?
  resgatadaEm    DateTime?
  expiradaEm     DateTime?
  canceladaEm    DateTime?
  canceladoPorId String?

  lote         LoteChave @relation(fields: [loteId], references: [id])
  campanha     Campanha  @relation(fields: [campanhaId], references: [id])
  loja         Loja      @relation(fields: [lojaId], references: [id])
  cliente      Cliente?  @relation(fields: [clienteId], references: [id])
  canceladoPor User?     @relation("CanceladoPor", fields: [canceladoPorId], references: [id])
  resgate      Resgate?
  logsEventos  LogEvento[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([loteId])
  @@index([campanhaId])
  @@index([lojaId])
  @@index([clienteId])
  @@index([canceladoPorId])
  @@index([status])
  @@map("chaves")
}

model Cliente {
  id          String      @id @default(cuid())
  telefone    String?
  email       String?
  nome        String?
  documento   String?
  ipCadastro  String?
  canalOrigem CanalOrigem @default(WEB)

  chaves      Chave[]
  resgates    Resgate[]
  logsEventos LogEvento[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("clientes")
}

model Resgate {
  id                String        @id @default(cuid())
  chaveId           String        @unique
  campanhaId        String
  lojaId            String
  clienteId         String?
  operadorId        String?
  canal             CanalResgate  @default(BALCAO)
  statusResgate     StatusResgate @default(CONFIRMADO)
  beneficioEntregue String?       @db.Text
  observacao        String?       @db.Text
  ipOrigem          String?

  chave    Chave    @relation(fields: [chaveId], references: [id])
  campanha Campanha @relation(fields: [campanhaId], references: [id])
  loja     Loja     @relation(fields: [lojaId], references: [id])
  cliente  Cliente? @relation(fields: [clienteId], references: [id])
  operador User?    @relation(fields: [operadorId], references: [id])

  resgatadoEm DateTime @default(now())

  @@index([campanhaId])
  @@index([lojaId])
  @@index([clienteId])
  @@index([operadorId])
  @@map("resgates")
}

model LogEvento {
  id         String     @id @default(cuid())
  tipoEvento TipoEvento
  chaveId    String?
  campanhaId String?
  lojaId     String?
  clienteId  String?
  operadorId String?
  canal      String?
  ipOrigem   String?
  userAgent  String?    @db.Text
  payload    Json?

  chave    Chave?    @relation(fields: [chaveId], references: [id])
  campanha Campanha? @relation(fields: [campanhaId], references: [id])
  loja     Loja?     @relation(fields: [lojaId], references: [id])
  cliente  Cliente?  @relation(fields: [clienteId], references: [id])
  operador User?     @relation(fields: [operadorId], references: [id])

  criadoEm DateTime @default(now())

  @@index([chaveId])
  @@index([campanhaId])
  @@index([lojaId])
  @@index([clienteId])
  @@index([operadorId])
  @@index([tipoEvento])
  @@index([criadoEm])
  @@map("logs_eventos")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum Role {
  SUPER_ADMIN
  LOJISTA
  CLIENTE
}

enum LojaStatus {
  ATIVA
  SUSPENSA
  CANCELADA
}

enum Plano {
  ESSENCIAL
  PROFISSIONAL
  EMPRESARIAL
}

enum TipoBeneficio {
  DESCONTO_PERCENTUAL
  DESCONTO_FIXO
  BRINDE
  SORTEIO
  FRETE_GRATIS
  CASHBACK
}

enum CampanhaStatus {
  RASCUNHO
  ATIVA
  PAUSADA
  ENCERRADA
  CANCELADA
}

enum FormatoSaida {
  A4
  ETIQUETA
  ADESIVO
  CSV
  DIGITAL
}

enum LoteStatus {
  GERADO
  EXPORTADO
  DISTRIBUIDO
}

enum ChaveStatus {
  GERADA
  CONSULTADA
  ATIVADA
  RESGATADA
  EXPIRADA
  CANCELADA
}

enum CanalOrigem {
  WEB
  QRCODE
  MANUAL
}

enum CanalResgate {
  BALCAO
  QRCODE
  WEB
  APP
  MANUAL
}

enum StatusResgate {
  CONFIRMADO
  RECUSADO
  ESTORNADO
}

// ─────────────────────────────────────────
// SOLICITAÇÕES DE IMPRESSÃO
// ─────────────────────────────────────────

model SolicitacaoImpressao {
  id              String            @id @default(cuid())
  lojaId          String
  campanhaId      String
  loteId          String
  layoutId        String
  quantidadeCards Int
  folhasEstimadas Int
  observacaoLoja  String?           @db.Text
  status          StatusSolicitacao @default(PENDENTE)
  observacaoAdmin String?           @db.Text
  aprovadoPorId   String?
  aprovadoEm      DateTime?

  loja        Loja      @relation(fields: [lojaId],     references: [id])
  campanha    Campanha  @relation(fields: [campanhaId],  references: [id])
  lote        LoteChave @relation(fields: [loteId],     references: [id])
  layout      Layout    @relation(fields: [layoutId],   references: [id])
  aprovadoPor User?     @relation("ImpressaoAprovacao", fields: [aprovadoPorId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([lojaId])
  @@index([campanhaId])
  @@index([loteId])
  @@index([layoutId])
  @@index([aprovadoPorId])
  @@index([status])
  @@map("solicitacoes_impressao")
}

enum StatusSolicitacao {
  PENDENTE
  EM_ANALISE
  APROVADA
  REJEITADA
  IMPRESSA
  ENTREGUE
}

enum TipoImpressao {
  PROPRIO
  ADMIN_COURTESYFY
}

enum TamanhoCard {
  MINI
  CARTAO
  PADRAO
  COUPON
  VOUCHER
  MEIO_A4
  MDF
}

enum EstiloCard {
  CLASSICO
  MODERNO
  MINIMALISTA
  GRADIENTE
  NEON
}

enum TipoEvento {
  CHAVE_GERADA
  CHAVE_CONSULTADA
  CHAVE_ATIVADA
  CHAVE_RESGATADA
  CHAVE_EXPIRADA
  CHAVE_CANCELADA
  TENTATIVA_INVALIDA
  TENTATIVA_REUSO
  RESGATE_RECUSADO
  CAMPANHA_CRIADA
  CAMPANHA_ENCERRADA
  LOTE_GERADO
  LOTE_EXPORTADO
  USUARIO_LOGIN
  USUARIO_LOGOUT
}
